CONNECT_MODE=remote
HOMESERVER_URL=
AGENT_SERVER_URL=http://127.0.0.1:4100
OWNER_ACCESS_TOKEN=
AGENT_LOCALPART=
AGENT_DISPLAY_NAME=
AGENT_DEVICE_DISPLAY_NAME=codex runtime
STATE_DIR=./storage/codex
STORAGE_PATH=./storage/codex/sdk-storage.json
PROVIDER=codex
PROVIDER_BIN=codex
CONTAINER_PROVIDER_BIN=codex
PROVIDER_CWD=./storage/codex
PROVIDER_MODEL=
DEFAULT_ROOM_MODE=shared
WORKSPACES_ROOT=./storage/codex/workspaces
DOCKER_BIN=docker
CONTAINER_IMAGE=matrix-agent-codex-runtime:local
CONTAINER_HOMES_ROOT=./storage/codex/container-homes
CONTAINER_HOME_DIR=/root
CONTAINER_CODEX_SEED_HOME=~/.codex
CONTAINER_WORKSPACE_DIR=/workspace
COMMAND_PREFIX=!
ROOM_ALLOWLIST=
CODEX_APPROVAL_POLICY=never
CODEX_SANDBOX_POLICY=dangerFullAccess
TYPING_TIMEOUT_MS=120000
STREAM_FLUSH_INTERVAL_SEC=0.5
STREAM_FLUSH_CHARS=24
COMMAND_OUTPUT_LIMIT=4000
COMMAND_RESULT_LIMIT=3500
CODEX_REQUEST_TIMEOUT_SEC=30
CODEX_TURN_TIMEOUT_SEC=120
CLI_COMMAND_TIMEOUT_SEC=300
