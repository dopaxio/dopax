CONNECT_MODE=remote
HOMESERVER_URL=
AGENT_SERVER_URL=http://127.0.0.1:4100
OWNER_ACCESS_TOKEN=
AGENT_LOCALPART=
AGENT_DISPLAY_NAME=opencode runtime
AGENT_DEVICE_DISPLAY_NAME=opencode runtime
STATE_DIR=./storage/opencode
STORAGE_PATH=./storage/opencode/sdk-storage.json
PROVIDER=opencode
PROVIDER_BIN=opencode
CONTAINER_PROVIDER_BIN=opencode
PROVIDER_CWD=./storage/opencode
PROVIDER_MODEL=
DEFAULT_ROOM_MODE=shared
WORKSPACES_ROOT=./storage/opencode/workspaces
DOCKER_BIN=docker
CONTAINER_IMAGE=matrix-agent-opencode-runtime:local
CONTAINER_HOMES_ROOT=./storage/opencode/container-state
CONTAINER_HOME_DIR=/root
CONTAINER_WORKSPACE_DIR=/workspace
COMMAND_PREFIX=!
ROOM_ALLOWLIST=
TYPING_TIMEOUT_MS=120000
STREAM_FLUSH_INTERVAL_SEC=0.5
STREAM_FLUSH_CHARS=24
COMMAND_OUTPUT_LIMIT=4000
COMMAND_RESULT_LIMIT=3500
CODEX_REQUEST_TIMEOUT_SEC=30
CODEX_TURN_TIMEOUT_SEC=120
CLI_COMMAND_TIMEOUT_SEC=300
