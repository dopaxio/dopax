CONNECT_MODE=remote
HOMESERVER_URL=
AGENT_SERVER_URL=http://127.0.0.1:4100
OWNER_ACCESS_TOKEN=
AGENT_LOCALPART=
AGENT_DISPLAY_NAME=gemini runtime
AGENT_DEVICE_DISPLAY_NAME=gemini runtime
STATE_DIR=./storage/gemini
STORAGE_PATH=./storage/gemini/sdk-storage.json
PROVIDER=gemini
PROVIDER_BIN=gemini
CONTAINER_PROVIDER_BIN=gemini
PROVIDER_CWD=./storage/gemini
PROVIDER_MODEL=
DEFAULT_ROOM_MODE=shared
WORKSPACES_ROOT=./storage/gemini/workspaces
DOCKER_BIN=docker
CONTAINER_IMAGE=matrix-agent-gemini-runtime:local
CONTAINER_HOMES_ROOT=./storage/gemini/container-state
CONTAINER_HOME_DIR=/root
CONTAINER_SEED_HOME=~/.gemini
CONTAINER_WORKSPACE_DIR=/workspace
COMMAND_PREFIX=!
ROOM_ALLOWLIST=
TYPING_TIMEOUT_MS=120000
STREAM_FLUSH_INTERVAL_SEC=0.5
STREAM_FLUSH_CHARS=24
COMMAND_OUTPUT_LIMIT=4000
COMMAND_RESULT_LIMIT=3500
CODEX_REQUEST_TIMEOUT_SEC=30
CODEX_TURN_TIMEOUT_SEC=120
CLI_COMMAND_TIMEOUT_SEC=300
